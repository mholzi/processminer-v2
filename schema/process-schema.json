  "elementTypes": {
    "role": {
      "label": "Role",
      "section": "roles",
      "idPrefix": "ROLE",
      "frontmatter": {
        "fields": [],
        "relations": [
          {
            "key": "systems",
            "label": "Systems",
            "target": "system"
          },
          {
            "key": "controls",
            "label": "Controls",
            "target": "control"
          }
        ],
        "required": []
      },
      "template": [
        {
          "heading": "Responsibility",
          "format": "paragraph",
          "paragraphs": "1",
          "words": "8–45",
          "purpose": "What the role owns in the process, stated in one clear sentence."
        },
        {
          "heading": "In this process",
          "format": "paragraph",
          "paragraphs": "1–2",
          "words": "10–50",
          "purpose": "The specific steps and controls this role performs in this process."
        }
      ]
    },
    "process-step": {
      "label": "Process Step",
      "section": "process-steps",
      "idPrefix": "PS",
      "frontmatter": {
        "fields": [
          {
            "key": "owner",
            "label": "Owner"
          },
          {
            "key": "sla",
            "label": "SLA"
          },
          {
            "key": "condition",
            "label": "Condition"
          }
        ],
        "relations": [
          {
            "key": "systems",
            "label": "Systems",
            "target": "system"
          }
        ],
        "required": [
          "owner"
        ],
        "transitions": {
          "format": "to|kind|when",
          "kinds": [
            "normal",
            "branch",
            "loopback",
            "exception"
          ],
          "note": "Outgoing flow from this step. Frontmatter key `transitions` — a list, each entry `<targetId>|<kind>|<when>`: the element it flows to (a process-step or exception id), the transition kind, and the condition under which it fires. Keep the `when` clause free of commas (the list is comma-delimited)."
        }
      },
      "template": [
        {
          "heading": "What happens",
          "format": "paragraph",
          "paragraphs": "1–2",
          "words": "20–95",
          "purpose": "The concrete actions performed in this step, in plain language."
        },
        {
          "heading": "Inputs",
          "format": "bullets",
          "items": "2–6",
          "purpose": "Each thing the step consumes — documents, data or prior outputs."
        },
        {
          "heading": "Outputs",
          "format": "bullets",
          "items": "2–6",
          "purpose": "Each thing the step produces and hands to the next step."
        },
        {
          "heading": "Why it matters",
          "format": "paragraph",
          "paragraphs": "1",
          "words": "10–60",
          "purpose": "The risk this step controls or the value it adds."
        }
      ]
    },
    "exception": {
      "label": "Exception",
      "section": "exceptions",
      "idPrefix": "EX",
      "frontmatter": {
        "fields": [
          {
            "key": "category",
            "label": "Category"
          },
          {
            "key": "frequencyPct",
            "label": "Frequency",
            "suffix": "%"
          },
          {
            "key": "impact",
            "label": "Impact"
          },
          {
            "key": "handlingOwner",
            "label": "Handling"
          }
        ],
        "relations": [],
        "required": [
          "category",
          "impact",
          "affects"
        ]
      },
      "template": [
        {
          "heading": "Description",
          "format": "paragraph",
          "paragraphs": "1",
          "words": "12–50",
          "purpose": "What the exception is and the conditions under which it arises."
        },
        {
          "heading": "Handling",
          "format": "paragraph",
          "paragraphs": "1–2",
          "words": "10–60",
          "purpose": "How the exception is resolved, and by whom."
        },
        {
          "heading": "Impact",
          "format": "paragraph",
          "paragraphs": "1",
          "words": "8–40",
          "purpose": "Effect on cycle time, cost, the client or compliance."
        }
      ]
    },
    "control": {
      "label": "Control",
      "section": "controls",
      "idPrefix": "CP",
      "frontmatter": {
        "fields": [
          {
            "key": "controlType",
            "label": "Type"
          },
          {
            "key": "execution",
            "label": "Execution"
          },
          {
            "key": "effectiveness",
            "label": "Effectiveness"
          },
          {
            "key": "owner",
            "label": "Owner"
          }
        ],
        "relations": [
          {
            "key": "step",
            "label": "Step",
            "target": "process-step",
            "reverseLabel": "Controls"
          },
          {
            "key": "regulatedBy",
            "label": "Regulated by",
            "target": "regulation"
          }
        ],
        "required": [
          "controlType",
          "execution",
          "owner",
          "step"
        ]
      },
      "template": [
        {
          "heading": "What it checks",
          "format": "paragraph",
          "paragraphs": "1",
          "words": "10–40",
          "purpose": "The specific risk or condition the control verifies."
        },
        {
          "heading": "Control activity",
          "format": "paragraph",
          "paragraphs": "1",
          "words": "10–50",
          "purpose": "How the control is performed, by whom and with what."
        },
        {
          "heading": "Risk addressed",
          "format": "paragraph",
          "paragraphs": "1",
          "words": "6–40",
          "purpose": "The risk that would materialise without this control."
        },
        {
          "heading": "Timing",
          "format": "paragraph",
          "paragraphs": "1",
          "words": "6–35",
          "purpose": "When and how often the control runs."
        }
      ]
    },
