# Processminer — required environment variables.
# Copy to .env.local and fill in. .env.local is gitignored.

# Used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PM_SESSION_SECRET=

# First-time bootstrap admin. Created on server startup if data/users.json
# is empty. Once an admin exists in users.json these are ignored.
PM_BOOTSTRAP_ADMIN_USER=admin
PM_BOOTSTRAP_ADMIN_PASS=
PM_BOOTSTRAP_ADMIN_NAME=Administrator
PM_BOOTSTRAP_ADMIN_ROLE=Platform Admin

# AI Assistant Session Provider configuration:
# - "gemini": Uses the in-process Gemini SDK (requires GEMINI_API_KEY).
# - "claude": Uses the real Anthropic Claude CLI via spawned child process.
#             Requires your local `claude` binary to be installed and authenticated.
#             (Connects to the local MCP server: src/lib/claude-mcp-server.ts)
SESSION_PROVIDER=claude

# Model name configuration (e.g. "claude-sonnet-4-6", "gemini-3.5-pro", "gemini-3.5-flash")
SESSION_MODEL=claude-sonnet-4-6

# Gemini API Key (Required if SESSION_PROVIDER is "gemini" and VERTEX_AI is not true)
GEMINI_API_KEY=

# Vertex AI Keyless Configuration (Alternative to GEMINI_API_KEY if using Google Cloud Vertex AI with Application Default Credentials)
# Set to "true" to route calls through Vertex AI using GCP preauthenticated credentials (ADC)
VERTEX_AI=false
# Your Google Cloud Project ID
GOOGLE_CLOUD_PROJECT=
# Google Cloud Region where your models are hosted
GOOGLE_CLOUD_LOCATION=us-central1

